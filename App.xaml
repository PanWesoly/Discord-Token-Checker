<Application x:Class="DiscordTokenChecker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- ═══ KOLORY ═══ -->
        <Color x:Key="BgDark">#2B2D31</Color>
        <Color x:Key="BgMedium">#313338</Color>
        <Color x:Key="BgDarkest">#1E1F22</Color>
        <Color x:Key="BgLight">#3F4147</Color>
        <Color x:Key="BgLighter">#4E5058</Color>
        <Color x:Key="Blurple">#5865F2</Color>
        <Color x:Key="Green">#23A55A</Color>
        <Color x:Key="Red">#F23F43</Color>
        <Color x:Key="Yellow">#F0B232</Color>

        <SolidColorBrush x:Key="BgDarkBrush"     Color="{StaticResource BgDark}"/>
        <SolidColorBrush x:Key="BgMediumBrush"   Color="{StaticResource BgMedium}"/>
        <SolidColorBrush x:Key="BgDarkestBrush"  Color="{StaticResource BgDarkest}"/>
        <SolidColorBrush x:Key="BgLightBrush"    Color="{StaticResource BgLight}"/>
        <SolidColorBrush x:Key="BgLighterBrush"  Color="{StaticResource BgLighter}"/>
        <SolidColorBrush x:Key="BlurpleBrush"    Color="{StaticResource Blurple}"/>
        <SolidColorBrush x:Key="GreenBrush"      Color="{StaticResource Green}"/>
        <SolidColorBrush x:Key="RedBrush"        Color="{StaticResource Red}"/>
        <SolidColorBrush x:Key="YellowBrush"     Color="{StaticResource Yellow}"/>

        <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#DBDEE1"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B5BAC1"/>
        <SolidColorBrush x:Key="TextMutedBrush"     Color="#80848E"/>

        <!-- ═══ PRZYCISKI ═══ -->
        <Style x:Key="DiscordButton" TargetType="Button">
            <Setter Property="Background"     Value="{StaticResource BlurpleBrush}"/>
            <Setter Property="Foreground"     Value="White"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="FontFamily"     Value="Segoe UI"/>
            <Setter Property="Padding"        Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4752C4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#3A3E6B"/>
                                <Setter Property="Foreground" Value="#6B6F8B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"     Value="{StaticResource BgLightBrush}"/>
            <Setter Property="Foreground"     Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="FontFamily"     Value="Segoe UI"/>
            <Setter Property="Padding"        Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BgLighterBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background"     Value="#C03537"/>
            <Setter Property="Foreground"     Value="White"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="FontFamily"     Value="Segoe UI"/>
            <Setter Property="Padding"        Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#A12B2D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
