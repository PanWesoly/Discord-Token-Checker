<Window x:Class="DiscordTokenChecker.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — Discord Token Checker"
        Width="360" SizeToContent="Height"
        MinWidth="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgDarkBrush}"
        FontFamily="Segoe UI"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Margin"      Value="0,5,0,5"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">

        <TextBlock Text="COLUMN VISIBILITY"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{StaticResource TextMutedBrush}"
                   Margin="0,0,0,14"/>

        <CheckBox x:Name="chkStatus"     Content="Status"             IsChecked="{Binding ShowStatus,     Mode=TwoWay}"/>
        <CheckBox x:Name="chkUsername"   Content="Username"           IsChecked="{Binding ShowUsername,   Mode=TwoWay}"/>
        <CheckBox x:Name="chkEmail"      Content="Email"              IsChecked="{Binding ShowEmail,      Mode=TwoWay}"/>
        <CheckBox x:Name="chkPhone"      Content="Phone"              IsChecked="{Binding ShowPhone,      Mode=TwoWay}"/>
        <CheckBox x:Name="chkNitro"      Content="Nitro"              IsChecked="{Binding ShowNitro,      Mode=TwoWay}"/>
        <CheckBox x:Name="chkNitroSince" Content="Nitro Since"        IsChecked="{Binding ShowNitroSince, Mode=TwoWay}"/>
        <CheckBox x:Name="chkTwoFA"      Content="2FA"                IsChecked="{Binding ShowTwoFA,      Mode=TwoWay}"/>
        <CheckBox x:Name="chkLocale"     Content="Locale"             IsChecked="{Binding ShowLocale,     Mode=TwoWay}"/>
        <CheckBox x:Name="chkVerified"   Content="Verified"           IsChecked="{Binding ShowVerified,   Mode=TwoWay}"/>
        <CheckBox x:Name="chkConnected"  Content="Connected Accounts" IsChecked="{Binding ShowConnected,  Mode=TwoWay}"/>
        <CheckBox x:Name="chkPayment"    Content="Payment"            IsChecked="{Binding ShowPayment,    Mode=TwoWay}"/>
        <CheckBox x:Name="chkToken"      Content="Token"              IsChecked="{Binding ShowToken,      Mode=TwoWay}"/>
        <CheckBox x:Name="chkCreated"    Content="Account Created"    IsChecked="{Binding ShowCreated,    Mode=TwoWay}"/>

        <Border Height="1" Background="{StaticResource BgLightBrush}" Margin="0,16,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Select All"    Width="120" Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButton}" Click="BtnSelectAll_Click"/>
            <Button Content="Deselect All"  Width="120"
                    Style="{StaticResource DangerButton}"   Click="BtnDeselectAll_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
